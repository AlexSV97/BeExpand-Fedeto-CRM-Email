# ── BeExpand CRM Email — Variables de entorno ──
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env

# ── Base de datos ──
# SQLite (desarrollo):
DATABASE_URL=sqlite+aiosqlite:///./beexpand.db
# PostgreSQL (producción con Docker):
# DATABASE_URL=postgresql+asyncpg://beexpand:beexpand_secret@localhost:5432/beexpand

# ── JWT ──
SECRET_KEY=cambiar-por-clave-segura-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin por defecto ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── IMAP (Gmail o el que uses) ──
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=beexpandcrmpoc@gmail.com
IMAP_PASSWORD=wdjqgpkkurdoxiqg
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_MINUTES=5
# Mapa de categorias a carpetas IMAP donde mover los emails tras clasificarlos.
# Formato JSON. Ejemplo:
#   IMAP_FOLDER_MAP={"cliente":"INBOX/Clientes","lead":"INBOX/Leads","proveedor":"INBOX/Proveedores"}
# Para desactivar: dejar vacio o como diccionario vacio {}
IMAP_FOLDER_MAP=

# ── VTiger CRM (opcional, dejar vacío si no se usa) ──
VTIGER_URL=
VTIGER_TOKEN=
VTIGER_USERNAME=

# ── Ollama (IA local) ──
# En Docker: http://host.docker.internal:11434
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=hermes3:8b
OLLAMA_TIMEOUT=30

# Modelo para el chat de onboarding (mas rapido en CPU)
CHAT_MODEL=phi4-mini
CHAT_TIMEOUT=120

# ── Redis / Celery ──
REDIS_URL=redis://localhost:6379/0

# ── BERT (modelo fine-tuneado) ──
# Ruta donde se guarda/carga el modelo BERT fine-tuneado.
# Vacio = usa la ruta por defecto (backend/src/classifier/model/).
# Util para sincronizar el modelo entre equipos via Dropbox/OneDrive:
#   BERT_MODEL_PATH=C:/Users/tu-usuario/Dropbox/BeExpand/bert-model
BERT_MODEL_PATH=

# ── Entorno ──
DEBUG=true

# ── Telegram (alertas de correos urgentes) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_URGENCY=alta
