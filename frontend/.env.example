# URL pública o local del backend FastAPI
# Desarrollo local directo contra backend:
VITE_API_URL=http://localhost:8001/api/v1

# Si usás Vite con proxy, podés omitir esta variable.
# Si desplegás el frontend por separado (sin proxy reverso), DEFINILA.
# Con el Docker+Nginx de este repo en Render, se usa /api/v1 y el proxy interno API_UPSTREAM.
# Ejemplo producción sin proxy:
# VITE_API_URL=https://tu-backend.onrender.com/api/v1
